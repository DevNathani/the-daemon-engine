echo "${C_WHITE} I whispered into the empty night...${RESET}"

echo

echo "${C_RED} I am inside the castle.${RESET}" 
sleep 0.05
echo "${C_YELLOW} Now I have only one motive.${RESET}" 
sleep 0.05
